# Configuración básica requerida para Paperless-ngx
# Revisa las configuraciones adicionales en https://docs.paperless-ngx.com/configuration/

# La URL del sitio. Cambia esto si vas a exponer el servidor en internet.
PAPERLESS_URL=http://localhost:8000

# Idioma principal para el reconocimiento de texto (OCR). spa es para Español.
PAPERLESS_OCR_LANGUAGE=spa

# Zona horaria (puedes ajustarla según tu país, por ejemplo America/Lima, America/Mexico_City)
PAPERLESS_TIME_ZONE=UTC

# Clave secreta (por seguridad debes cambiar esto a algo aleatorio)
PAPERLESS_SECRET_KEY=change-this-to-a-very-random-secret-key-please

# Mapeo de usuario para que en los volúmenes queden con el usuario correcto
USERMAP_UID=1000
USERMAP_GID=1000
